pipeline {
    agent { label 'agent2' }

    stages {

        stage('Checkout Stage') {
            steps {
                git branch: 'main', 
                    url: 'https://github.com/hamsapriya2610-dotcom/git26.git'
            }
        }

        stage('Maven Build') {
            steps {
                sh 'mvn clean install'
            }
        }
    }
}
